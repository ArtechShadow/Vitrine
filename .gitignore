.idea
.vs/
.claude
imgui.ini
lichtfeld-studio.aps

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
CLAUDE.md
build/
build*/
build*/**
# ...but the C++ build ignore above is unanchored, so re-include the docs/build/
# documentation tree it would otherwise swallow (the "Build (Linux)" guide etc.).
!docs/build/
!docs/build/**
cmake-build-debug/
cmake-build-release/
output*
results
testdata
test-data/

# ---------------------------------------------------------------------------
# Dependencies / vendored libraries
# ---------------------------------------------------------------------------
external/libtorch/
external/libtorch
external/release/libtorch/
external/debug/libtorch/
vcpkg/
vcpkg/**
vcpkg_*/
vcpkg_*/**

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
# NOTE: do NOT add `*.py` here — it silently ignores ALL Python source (this
# previously dropped src/web/{scenes,files,zip,splat}_api.py from the repo).
# Ignore only byte-compiled artifacts + virtualenvs; vendored/scratch Python is
# covered by the data/, vendor/, output/, build/ rules elsewhere.
__pycache__/
*.pyc
.venv/
.venv*/
test.py
src/python/stubs/lichtfeld/build_info.pyi
# Keep these tracked sources despite the blanket *.py / *.sh ignores:
!scripts/lichtfeld_mcp_bridge.py
!scripts/hardware_trace.py
!scripts/run_gallery_pipeline.py
!scripts/ppisp_report.py
!scripts/extract_strings.py
!scripts/validate_localization.py
!scripts/benchmark_omniblender.sh
!scripts/test_*.py
# Dreamlab scene/object mesh pipeline (CoMe + TSDF -> texture -> FBX -> UE; see docs/engineering-log.md):
!scripts/tsdf_room.py
!scripts/scene_texture.py
!scripts/scene_texture_fast.py
!scripts/scene_to_ue.py
!scripts/blender_obj_to_fbx.py
!scripts/blender_room_compare.py
!scripts/blender_scene_assemble.py
!scripts/blender_object_showcase.py
!scripts/blender_prescale_objects.py
!scripts/come_color_texture.py
!scripts/compute_placements.py
!scripts/hy3d_one.py
!scripts/hy3d_turnaround.py
!scripts/comfy_run.py
!scripts/render_splat_views.py
!scripts/e2e_downstream_validate.py
!scripts/exhibit_builder.py
!scripts/splat_clean.py
!unreal/runtime/**/*.py
!src/python/_lfs_panel_contract.py
!src/python/lfs_splat_lod_hierarchy.py
!src/python/lfs_plugins/**/*.py
!src/python/scripts/manage_stubs.py
!src/pipeline/**/*.py
!tests/real_bicycle_sh_degree_training.py
!tests/python/**/*.py
!docs/plugins/examples/**/*.py

