{
  "_comment": "TRELLIS.2-4B full-360 multiview -> PBR-textured GLB hull (ADR-015 designated primary). Node class_types validated vs the live vitrine-comfyui /object_info (ComfyUI-TRELLIS2). Inputs are SIX orbit-render panels from the splat (front/left/back/right + top + bottom caps), each background-removed and fed to Trellis2MultiViewImageToShape so the whole surface (incl. top face + underside) is reconstructed — not just the visible front (a single-view feed leaves the back/top hallucinated). DINOv3 conditioning staged at models/dinov3/model.safetensors. The *_PLACEHOLDER filenames are substituted by trellis2_client.py (which renders the 6 panels via the renderer's trellis_6 preset). Terminal Preview3D registers the GLB in /history for client retrieval. Sequential VRAM load/unload on a 48GB card.",
  "1": {"class_type": "LoadTrellis2Models", "inputs": {"resolution": "1536_cascade"}, "_meta": {"title": "Load TRELLIS.2 models (max-fidelity 1536 cascade)"}},
  "10": {"class_type": "LoadImage", "inputs": {"image": "FRONT_IMAGE_PLACEHOLDER"}, "_meta": {"title": "Front view"}},
  "11": {"class_type": "LoadImage", "inputs": {"image": "LEFT_IMAGE_PLACEHOLDER"}, "_meta": {"title": "Left view"}},
  "12": {"class_type": "LoadImage", "inputs": {"image": "BACK_IMAGE_PLACEHOLDER"}, "_meta": {"title": "Back view"}},
  "13": {"class_type": "LoadImage", "inputs": {"image": "RIGHT_IMAGE_PLACEHOLDER"}, "_meta": {"title": "Right view"}},
  "14": {"class_type": "LoadImage", "inputs": {"image": "TOP_IMAGE_PLACEHOLDER"}, "_meta": {"title": "Top view (cap)"}},
  "15": {"class_type": "LoadImage", "inputs": {"image": "BOTTOM_IMAGE_PLACEHOLDER"}, "_meta": {"title": "Bottom view (underside)"}},
  "20": {"class_type": "Trellis2RemoveBackground", "inputs": {"image": ["10", 0]}, "_meta": {"title": "Matte front"}},
  "21": {"class_type": "Trellis2RemoveBackground", "inputs": {"image": ["11", 0]}, "_meta": {"title": "Matte left"}},
  "22": {"class_type": "Trellis2RemoveBackground", "inputs": {"image": ["12", 0]}, "_meta": {"title": "Matte back"}},
  "23": {"class_type": "Trellis2RemoveBackground", "inputs": {"image": ["13", 0]}, "_meta": {"title": "Matte right"}},
  "24": {"class_type": "Trellis2RemoveBackground", "inputs": {"image": ["14", 0]}, "_meta": {"title": "Matte top"}},
  "25": {"class_type": "Trellis2RemoveBackground", "inputs": {"image": ["15", 0]}, "_meta": {"title": "Matte bottom"}},
  "30": {"class_type": "Trellis2GetConditioning", "inputs": {"model_config": ["1", 0], "image": ["20", 0], "mask": ["20", 1], "background_color": "black"}, "_meta": {"title": "DINOv3 conditioning (front)"}},
  "40": {"class_type": "Trellis2MultiViewImageToShape", "inputs": {"model_config": ["1", 0], "front_image": ["20", 0], "front_mask": ["20", 1], "left_image": ["21", 0], "left_mask": ["21", 1], "back_image": ["22", 0], "back_mask": ["22", 1], "right_image": ["23", 0], "right_mask": ["23", 1], "top_image": ["24", 0], "top_mask": ["24", 1], "bottom_image": ["25", 0], "bottom_mask": ["25", 1], "seed": 42, "ss_sampling_steps": 12, "shape_sampling_steps": 12, "front_axis": "z", "background_color": "black"}, "_meta": {"title": "Full-360 multiview (front/left/back/right/top/bottom) -> shape"}},
  "45": {"class_type": "Trellis2ProcessMesh", "inputs": {"trimesh": ["40", 0], "remesh": true, "target_face_count": 500000}, "_meta": {"title": "Process mesh (remesh + decimate before PBR bake)"}},
  "50": {"class_type": "Trellis2ShapeToTexturedMesh", "inputs": {"model_config": ["1", 0], "conditioning": ["30", 0], "shape_slat": ["40", 1], "subs": ["40", 2], "seed": 42, "tex_sampling_steps": 12}, "_meta": {"title": "Shape -> textured voxelgrid (PBR)"}},
  "60": {"class_type": "Trellis2RasterizePBR", "inputs": {"trimesh": ["45", 0], "voxelgrid": ["50", 0], "texture_size": 4096, "original_mesh": ["40", 0]}, "_meta": {"title": "Rasterize PBR @4096 (albedo/metallic/roughness); original_mesh ref required"}},
  "70": {"class_type": "Trellis2ExportTrimesh", "inputs": {"trimesh": ["60", 0], "filename_prefix": "vitrine_hull", "file_format": "glb"}, "_meta": {"title": "Export GLB"}},
  "80": {"class_type": "Preview3D", "inputs": {"model_file": ["70", 0]}, "_meta": {"title": "Preview3D (registers the GLB in /history for client retrieval)"}}
}
