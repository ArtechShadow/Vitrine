{
  "_comment": "FLUX.2 generative view completion (ADR-017). Generates a plausible NOVEL view of an object for a 360 panel slot the splat never observed, conditioned on 1-2 observed reference views (VAE-encoded -> ReferenceLatent, FLUX.2 kontext-style) + a long JSON-structured prompt (Mistral-3 encoder). The client substitutes REF1/REF2_IMAGE_PLACEHOLDER (observed panels, highest coverage), PROMPT_PLACEHOLDER (JSON describing object + target view + consistency constraints), and the canvas W/H. Output is a single completed panel for TRELLIS.2. Coverage-gated upstream: only called for genuinely-unobserved slots (do-no-harm to real geometry).",
  "1":  {"class_type": "UNETLoader", "inputs": {"unet_name": "flux2_dev_fp8mixed.safetensors", "weight_dtype": "default"}, "_meta": {"title": "FLUX.2 diffusion"}},
  "2":  {"class_type": "CLIPLoader", "inputs": {"clip_name": "mistral_3_small_flux2_fp8.safetensors", "type": "flux2"}, "_meta": {"title": "Mistral-3 text encoder"}},
  "3":  {"class_type": "VAELoader", "inputs": {"vae_name": "flux2-vae.safetensors"}, "_meta": {"title": "FLUX.2 VAE"}},
  "4":  {"class_type": "LoadImage", "inputs": {"image": "REF1_IMAGE_PLACEHOLDER"}, "_meta": {"title": "Observed reference view 1"}},
  "5":  {"class_type": "VAEEncode", "inputs": {"pixels": ["4", 0], "vae": ["3", 0]}, "_meta": {"title": "Encode ref 1"}},
  "16": {"class_type": "LoadImage", "inputs": {"image": "REF2_IMAGE_PLACEHOLDER"}, "_meta": {"title": "Observed reference view 2"}},
  "17": {"class_type": "VAEEncode", "inputs": {"pixels": ["16", 0], "vae": ["3", 0]}, "_meta": {"title": "Encode ref 2"}},
  "7":  {"class_type": "CLIPTextEncode", "inputs": {"text": "PROMPT_PLACEHOLDER", "clip": ["2", 0]}, "_meta": {"title": "JSON prompt (object + target view + constraints)"}},
  "8":  {"class_type": "CLIPTextEncode", "inputs": {"text": "blurry, distorted, extra objects, text, watermark, inconsistent colour, different object", "clip": ["2", 0]}, "_meta": {"title": "Negative"}},
  "9":  {"class_type": "FluxGuidance", "inputs": {"conditioning": ["7", 0], "guidance": 4.0}, "_meta": {"title": "FLUX guidance"}},
  "11": {"class_type": "ReferenceLatent", "inputs": {"conditioning": ["9", 0], "latent": ["5", 0]}, "_meta": {"title": "Reference latent (view 1)"}},
  "12": {"class_type": "ReferenceLatent", "inputs": {"conditioning": ["11", 0], "latent": ["17", 0]}, "_meta": {"title": "Reference latent (view 2)"}},
  "6":  {"class_type": "EmptyFlux2LatentImage", "inputs": {"width": 512, "height": 512, "batch_size": 1}, "_meta": {"title": "New-view canvas"}},
  "13": {"class_type": "KSampler", "inputs": {"model": ["1", 0], "positive": ["12", 0], "negative": ["8", 0], "latent_image": ["6", 0], "seed": 42, "steps": 28, "cfg": 1.0, "sampler_name": "euler", "scheduler": "simple", "denoise": 1.0}, "_meta": {"title": "KSampler"}},
  "14": {"class_type": "VAEDecode", "inputs": {"samples": ["13", 0], "vae": ["3", 0]}, "_meta": {"title": "Decode"}},
  "15": {"class_type": "SaveImage", "inputs": {"filename_prefix": "flux2_view", "images": ["14", 0]}, "_meta": {"title": "Save completed view"}}
}
