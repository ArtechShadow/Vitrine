# Vitrine web frontend — build/runtime configuration.
# Copy to `.env` for local development. Every value is optional; the app runs
# entirely against the same-origin loopback backend with no configuration.
#
# There is intentionally NO preview/mock layer: the SPA only ever talks to the
# real Flask backend on 127.0.0.1:7860 (VITE_PREVIEW_MODE / previewApi are not
# supported and do not exist).

# Public base path the built assets are served from (Flask static mount).
# Must match where Dockerfile bakes dist/ (src/web/static/spa -> /static/spa/).
# VITE_BASE=/static/spa/

# Backend the dev server proxies /api and /stream to. Loopback only.
# VITE_DEV_BACKEND=http://127.0.0.1:7860

# Optional sample splat for the viewer empty-state (a small committed .ksplat).
# When set, the immersive viewer offers it as a demo when a scene has no splat.
# VITE_DEMO_SPLAT_URL=/static/spa/demo/sample.ksplat
