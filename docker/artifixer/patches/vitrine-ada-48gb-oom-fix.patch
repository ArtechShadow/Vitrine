+def _maybe_enable_vae_tiling(vae):
+    """OOM mitigation (ArtiFixer-Ada): tile Wan VAE encode/decode on small GPUs.
+
+    Enabled via env ARTIFIXER_VAE_TILING=1. Tile sizes overridable via
+    ARTIFIXER_VAE_TILE_MIN (sample px, default 256) and
+    ARTIFIXER_VAE_TILE_STRIDE (sample px, default 192). Engages diffusers
+    AutoencoderKLWan.tiled_encode / tiled_decode when a frame dim exceeds
+    tile_sample_min_{height,width}; covers every rgb_to_latents / latents_to_rgb
+    site (frame encode, neighbor encode, final decode).
+    """
+    import os
+
+    if os.environ.get("ARTIFIXER_VAE_TILING", "0") not in ("1", "true", "True"):
+        return vae
+    tmin = int(os.environ.get("ARTIFIXER_VAE_TILE_MIN", "256"))
+    tstride = int(os.environ.get("ARTIFIXER_VAE_TILE_STRIDE", "192"))
+    if hasattr(vae, "enable_tiling"):
+        vae.enable_tiling(
+            tile_sample_min_height=tmin,
+            tile_sample_min_width=tmin,
+            tile_sample_stride_height=tstride,
+            tile_sample_stride_width=tstride,
+        )
+        print(
+            "[ArtiFixer-Ada] VAE tiling ENABLED (use_tiling=%s, min=%d, stride=%d)"
+            % (getattr(vae, "use_tiling", None), tmin, tstride),
+            flush=True,
+        )
+    else:
+        print("[ArtiFixer-Ada] WARNING: vae has no enable_tiling()", flush=True)
+    return vae
+
+
