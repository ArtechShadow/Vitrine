 def resize_to_multiple_of_16(tensor: torch.Tensor) -> torch.Tensor:
-    """Resize tensor spatial dimensions to be multiples of 16."""
+    """Resize tensor spatial dimensions to be multiples of 16.
+
+    OOM mitigation (ArtiFixer-Ada): env ARTIFIXER_ENHANCE_DOWNSCALE=<f> (f>1)
+    additionally divides H,W by f before the /16 rounding. The KV cache, VAE
+    activations and transformer cost scale with the latent token count (~res^2),
+    so on a single 48GB card the full-res (1968x3398) trajectory render OOMs at
+    _initialize_kv_cache even with VAE tiling. Downscaling the enhance inputs
+    here keeps all resolution-bearing tensors (rgb_rendered/gt/neighbors/opacity)
+    consistent, and camera intrinsics are stored as ratios so they stay correct.
+    Default (env unset / 1) preserves upstream behaviour.
+    """
+    import os as _os
+
     h, w = tensor.shape[-2:]
+    try:
+        _ds = float(_os.environ.get("ARTIFIXER_ENHANCE_DOWNSCALE", "1") or "1")
+    except ValueError:
+        _ds = 1.0
+    if _ds and _ds > 1.0:
+        h = h / _ds
+        w = w / _ds
     new_h = round(h / 16) * 16
     new_w = round(w / 16) * 16
-    if new_h != h or new_w != w:
+    orig_h, orig_w = tensor.shape[-2:]
+    if new_h != orig_h or new_w != orig_w:
         return F.interpolate(tensor, (new_h, new_w), mode="bilinear")
     return tensor
 
