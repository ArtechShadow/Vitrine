.git/
# Large runtime trees — never part of any image build context. data/ holds the
# unified models tree (~216G) + comfyui runtime + raw captures; unreal/engine/ is
# the ~73G UE build. The unreal image still COPYs unreal/runtime/ (kept tracked).
data/
unreal/engine/
# Build outputs — provided at runtime via bind mount (build/ -> /opt/.../build:ro)
# or are local build artifacts, never needed in the image context.
build/
build*/
# Nested build artifacts under the vendored submodule (never needed; the
# lichtfeld-builder stage builds fresh from the COPY'd source).
vendor/lichtfeld-studio/build/
vendor/lichtfeld-studio/build*/
# Dev-only raw test captures (~2.3G of DNGs) — staged via the web UI, not baked.
rawsForDev/
onboarding/target/
external/libtorch/
